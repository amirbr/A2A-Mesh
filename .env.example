# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://a2a_mesh:password@localhost:5435/a2a_mesh
TEST_DATABASE_URL=postgresql+asyncpg://a2a_mesh:password@localhost:5436/a2a_mesh_test

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600

# ─── Federation ──────────────────────────────────────────────────────────────
# Company's own namespace (url-safe, e.g. "acme")
COMPANY_NAMESPACE=local
