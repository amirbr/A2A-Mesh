      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "FUTURE PHASES \u2014 TRIGGERED BY AN ACTUAL CEILING, NOT A CALENDAR DATE",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "FUTURE PHASES \u2014 TRIGGERED BY AN ACTUAL CEILING, NOT A CALENDAR DATE",
      "lineHeight": 1.25,
      "baseline": 12
    },
    {
      "id": "f_p2_79",
      "type": "rectangle",
      "x": 20,
      "y": 912,
      "width": 920,
      "height": 118,
      "strokeColor": "#7048e8",
      "backgroundColor": "#f3f0ff",
      "fillStyle": "solid",
      "strokeWidth": 1.5,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "g_f_p2"
