      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "PHASE 3 \u2014 Customer BYO Runner\n\nTrigger: a real prospect needs data-residency / \"never leaves our AWS.\"\n\nRunner = small container the customer deploys in their own cloud. Opens an OUTBOUND-ONLY\nconnection to our control plane \u2014 no inbound ports, no customer credentials ever touch our\ninfra. Runs the exact same GenericAgent code as Phase 1/2.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PHASE 3 \u2014 Customer BYO Runner\n\nTrigger: a real prospect needs data-residency / \"never leaves our AWS.\"\n\nRunner = small container the customer deploys in their own cloud. Opens an OUTBOUND-ONLY\nconnection to our control plane \u2014 no inbound ports, no customer credentials ever touch our\ninfra. Runs the exact same GenericAgent code as Phase 1/2.",
      "lineHeight": 1.25,
      "baseline": 10
    },
