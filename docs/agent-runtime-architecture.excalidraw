    {
      "id": "l_note_37",
      "type": "text",
      "x": 140,
      "y": 410,
      "width": 660,
      "height": 32,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "g_l_note"
      ],
      "frameId": null,
      "roundness": null,
      "seed": 173,
      "version": 1,
      "versionNonce": 174,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "\u2191 all three live in ONE process, ONE OS user, ONE event loop \u2014 calls between them are direct\nPython calls, not real network hops",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "\u2191 all three live in ONE process, ONE OS user, ONE event loop \u2014 calls between them are direct\nPython calls, not real network hops",
      "lineHeight": 1.25,
      "baseline": 10
    },
    {
      "id": "l_warn_38",
      "type": "rectangle",
      "x": 140,
      "y": 452,
      "width": 660,
      "height": 158,
      "strokeColor": "#c92a2a",
      "backgroundColor": "#ffe3e3",
      "fillStyle": "solid",
      "strokeWidth": 1.5,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "g_l_warn"
      ],
      "frameId": null,
      "roundness": {
        "type": 3
      },
      "seed": 175,
      "version": 1,
      "versionNonce": 176,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "l_warnt_39",
      "type": "text",
      "x": 154,
      "y": 454,
      "width": 632,
      "height": 154,
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "g_l_warn"
      ],
      "frameId": null,
      "roundness": null,
      "seed": 177,
      "version": 1,
      "versionNonce": 178,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "\u26a0  WHAT THIS COSTS US\n\n\u2022  No isolation beyond company_id checks in the API layer\n\u2022  Process restart \u21d2 every agent gone (DB still says \"running\")\n\u2022  Can't horizontally scale \u2014 a 2nd API process starts with an empty registry\n\u2022  tools.py::run_tests() subprocess shares this process's filesystem + network access\n    \u2192 a buggy or prompt-injected generated test becomes arbitrary code execution\n    on the platform's own process",
      "fontSize": 12.5,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u26a0  WHAT THIS COSTS US\n\n\u2022  No isolation beyond company_id checks in the API layer\n\u2022  Process restart \u21d2 every agent gone (DB still says \"running\")\n\u2022  Can't horizontally scale \u2014 a 2nd API process starts with an empty registry\n\u2022  tools.py::run_tests() subprocess shares this process's filesystem + network access\n    \u2192 a buggy or prompt-injected generated test becomes arbitrary code execution\n    on the platform's own process",
      "lineHeight": 1.25,
      "baseline": 10
    },
