      "roundness": null,
      "seed": 249,
      "version": 1,
      "versionNonce": 250,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "\u2713  WHAT THIS FIXES\n\n\u2022  Crash containment \u2014 one container dies, the rest keep running\n\u2022  API-process restart no longer loses every deployed agent\n\u2022  Resource limits stop one runaway agent from starving the others\n\u2022  Horizontal scaling becomes possible (2nd API process just calls the same Docker Engine API)\n\u2022  Closes the tools.py::run_tests() sandbox-escape gap from \u00a72",
      "fontSize": 12.5,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2713  WHAT THIS FIXES\n\n\u2022  Crash containment \u2014 one container dies, the rest keep running\n\u2022  API-process restart no longer loses every deployed agent\n\u2022  Resource limits stop one runaway agent from starving the others\n\u2022  Horizontal scaling becomes possible (2nd API process just calls the same Docker Engine API)\n\u2022  Closes the tools.py::run_tests() sandbox-escape gap from \u00a72",
      "lineHeight": 1.25,
      "baseline": 10
    },
